# Local: copy to `.env` in the project root (this file is NOT uploaded to Git).
# Restart `npm start` after changes. No trailing slash on URLs.

REACT_APP_API_BASE=https://payment.meena-health.com/api
REACT_APP_PAYMENT_API_BASE=https://payment.meena-health.com/api

# Legacy fallback for `getAppApiBaseUrl()` only:
REACT_APP_BASE_URL=

# Vercel: add the SAME keys and values under Project → Settings → Environment
# Variables (Production + Preview), then redeploy. The live site does not read your
# laptop’s `.env` file. If the API blocks cross-origin requests, allow your Vercel
# domain in the backend CORS settings.
