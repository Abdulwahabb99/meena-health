# Base URL for payment APIs (no trailing slash). Endpoint path /Moyasar is appended in code.
# Example: https://payment.meena-health.com/api
# Required for production builds. After changing, restart `npm start` or rebuild.
REACT_APP_PAYMENT_API_BASE=

# Dev: if this is empty, the app uses https://payment.meena-health.com/api so you still see network calls.
