# Copy to `.env` in the project root. Restart `npm start` after any change.
# No trailing slash on URLs.

# Required for Auth, Items, etc. (main axios client)
REACT_APP_API_BASE=https://payment.meena-health.com/api

# Optional legacy name; used only if REACT_APP_API_BASE is empty
REACT_APP_BASE_URL=

# Payment API (Moyasar). Also used as fallback for main API if the two vars above are empty.
REACT_APP_PAYMENT_API_BASE=https://payment.meena-health.com/api
